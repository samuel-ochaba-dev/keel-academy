# Auth.js v5 — required. Generate with: npx auth secret
AUTH_SECRET=replace-with-a-long-random-string

# Behind a proxy / non-localhost, Auth.js needs this. Leave true for local dev.
AUTH_TRUST_HOST=true

# Database. M0 defaults to a local libSQL file, so these are OPTIONAL locally.
# For a real Turso database, set both.
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# Magic-link email. In dev the link is printed to the terminal, so no key is
# needed. Set a Resend key later (M4) to send real emails.
# RESEND_API_KEY=
