# Environment contract — validated at build time by apps/web/lib/env.ts.
# Copy to apps/web/.env.local and fill in. Keep this file in sync with the
# Zod schema in lib/env.ts (schema = source of truth, this file = the doc).

# --- Auth.js v5 (required) ---
# Session/JWT encryption secret. Generate with: npx auth secret
AUTH_SECRET=replace-with-a-long-random-string

# Trust the forwarded Host header (needed behind a proxy / non-localhost).
# Leave true for local dev. Optional.
AUTH_TRUST_HOST=true

# Set automatically by Vercel. If VERCEL_ENV=production or
# NEXT_PUBLIC_PADDLE_ENV=production, the build fails unless full Paddle billing
# configuration is present and BILLING_FORCE_ENABLED is unset.
# VERCEL_ENV=development

# --- Database (optional locally) ---
# Defaults to a local libSQL file, so these can be omitted for local dev.
# For a real Turso database, set both.
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# --- Magic-link email (Resend) ---
# In dev the sign-in link is printed to the terminal, so no key is needed.
# Set a Resend API key to send real emails (from a Resend-verified domain).
# AUTH_RESEND_KEY=
# From address for magic-link emails. Optional; defaults to the value below.
# EMAIL_FROM=Keelacademy <login@keelacademy.dev>

# --- GitHub OAuth (optional) ---
# Set BOTH to enable "Continue with GitHub" on the sign-in page. Create an
# OAuth app at https://github.com/settings/developers with callback URL
# http://localhost:3000/api/auth/callback/github (use your domain in prod).
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=

# --- Google OAuth (optional) ---
# Set BOTH to enable "Continue with Google" on the sign-in page. Create an
# OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# (Application type: Web application) with authorized redirect URI
# http://localhost:3000/api/auth/callback/google (use your domain in prod).
# Before launch, complete Google OAuth consent-screen brand verification so the
# app can request email and profile scopes without the "unverified" warning.
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# --- Billing: Paddle (optional) ---
# When these are unset, the app runs in OPEN MODE: no paywall, every chapter is
# readable (keeps local dev and CI running with no payment secrets). Set them to
# enable enrollment gating. Use a Paddle SANDBOX account for testing.
#
# Server SDK: API key + webhook signing secret. The webhook secret starts with
# `pdl_ntfset_` and is shown once when you create the webhook destination under
# Paddle > Developer tools > Notifications.
# PADDLE_API_KEY=
# PADDLE_WEBHOOK_SECRET=
#
# Client: sandbox|production (defaults to sandbox), the client-side token from
# Paddle > Developer tools > Authentication, and the two price ids to sell.
# NEXT_PUBLIC_PADDLE_ENV=sandbox
# NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
# NEXT_PUBLIC_PADDLE_PRICE_MONTHLY=
# NEXT_PUBLIC_PADDLE_PRICE_LIFETIME=

# Dev-only: force the paywall ON without real Paddle secrets so the M5 gating
# UI (lock badges, paywall, billing plan cards) is visible locally. Checkout
# buttons stay disabled (no Paddle.js token); the webhook route still 503s.
# Never set this in production.
# BILLING_FORCE_ENABLED=true

# --- Observability: Sentry (optional) ---
# Sentry DSN for error monitoring. Optional: when unset Sentry is a no-op.
# https://docs.sentry.io/platforms/javascript/guides/nextjs/
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# --- Background jobs: Inngest (optional) ---
# Event key for sending events from the app to Inngest. Optional: when unset
# Inngest workflows are skipped. Signing key for verifying inbound calls.
# https://www.inngest.com/docs/events
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=
