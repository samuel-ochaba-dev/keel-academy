{
  "name": "keelacademy",
  "version": "0.0.0",
  "private": true,
  "description": "An online school for software engineers who can make things work but can't make things hold.",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "content": "turbo run content",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md,mdx,json}\"",
    "db:push": "pnpm --filter web db:push",
    "db:studio": "pnpm --filter web db:studio"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.10.4",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  }
}
