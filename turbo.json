{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "AUTH_SECRET",
    "AUTH_TRUST_HOST",
    "AUTH_GITHUB_ID",
    "AUTH_GITHUB_SECRET",
    "AUTH_GOOGLE_ID",
    "AUTH_GOOGLE_SECRET",
    "AUTH_RESEND_KEY",
    "EMAIL_FROM",
    "TURSO_DATABASE_URL",
    "TURSO_AUTH_TOKEN",
    "SKIP_ENV_VALIDATION",
    "KEEL_API_URL",
    "NEXT_RUNTIME",
    "SENTRY_DSN",
    "SENTRY_ORG",
    "SENTRY_PROJECT",
    "SENTRY_AUTH_TOKEN"
  ],
  "tasks": {
    "content": {
      "outputs": [".velite/**"]
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "!.next/dev/**", ".velite/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "env": [
        "NEXT_RUNTIME",
        "SENTRY_DSN",
        "SENTRY_ORG",
        "SENTRY_PROJECT",
        "SENTRY_AUTH_TOKEN"
      ]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": ["coverage/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^content"]
    }
  }
}
